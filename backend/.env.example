# Backend environment. Copy to `.env` and adjust. Never commit `.env`.

# ----- Application -----
APP_ENV=development                    # development | test | production
LOG_LEVEL=INFO

# ----- Database -----
# asyncpg driver is required (sync drivers are rejected by the engine factory).
#
# Two roles by design:
#   * ``DATABASE_URL`` (dataprep_app) — runtime + tests, RLS applies.
#   * ``DATABASE_ADMIN_URL`` (dataprep) — migrations and test fixture setup;
#     this role owns the tables and is allowed to TRUNCATE / DROP.
# The ``dataprep_app`` role is created by backend/scripts/init-app-role.sql
# the first time the Postgres volume is initialised.
DATABASE_URL=postgresql+asyncpg://dataprep_app:dataprep_app_dev@localhost:5432/dataprep
DATABASE_ADMIN_URL=postgresql+asyncpg://dataprep:dataprep_dev@localhost:5432/dataprep
TEST_DATABASE_URL=postgresql+asyncpg://dataprep_app:dataprep_app_dev@localhost:5432/dataprep_test
TEST_DATABASE_ADMIN_URL=postgresql+asyncpg://dataprep:dataprep_dev@localhost:5432/dataprep_test
SQL_ECHO=false

# ----- JWT -----
# HS256 is acceptable for v0. Production should migrate to RS256/EdDSA so the
# verifier does not need the signing secret. Generate a fresh secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-to-a-long-random-value-before-running-anything
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900             # 15 min
JWT_REFRESH_TTL_SECONDS=2592000        # 30 days
JWT_EMAIL_VERIFY_TTL_SECONDS=86400     # 24 h
JWT_PASSWORD_RESET_TTL_SECONDS=3600    # 1 h
JWT_MFA_PENDING_TTL_SECONDS=300        # 5 min

# ----- Encryption (TOTP secrets at rest) -----
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-with-a-fernet-key-44-chars-base64=

# ----- Cookies -----
COOKIE_SECURE=false                    # MUST be true in production (HTTPS only)
COOKIE_DOMAIN=                         # empty for localhost; set in production
COOKIE_SAMESITE=strict

# ----- CORS -----
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000

# ----- Frontend (used to build links in emails) -----
FRONTEND_URL=http://localhost:3000

# ----- Rate limiting -----
RATE_LIMIT_BACKEND=memory              # memory | redis (redis not wired in v0)
REDIS_URL=redis://localhost:6379/0
