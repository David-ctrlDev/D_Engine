# Root-level env vars consumed by docker-compose.yml.
# Copy to `.env` and adjust for your local setup. Never commit `.env`.

# ----- Postgres -----
POSTGRES_USER=dataprep
POSTGRES_PASSWORD=dataprep_dev
POSTGRES_DB=dataprep
POSTGRES_PORT=5432

# ----- Redis (defined for v0; not yet used by the app) -----
REDIS_PORT=6379
